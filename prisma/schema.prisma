generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Donation {
  id          String   @id @default(cuid())
  title       String
  category    String
  servings    Int
  pickupTime  String
  location    String
  createdAt   DateTime @default(now())
}