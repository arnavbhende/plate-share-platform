generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String
  createdAt DateTime @default(now())
}

model Donation {
  id                  String   @id @default(cuid())
  title               String
  category            String
  dietary             String
  description         String?
  servings            Int
  shelfLife           String
  handling            String?
  pickupTime          DateTime
  pickupSlot          String
  location            String
  locationName        String
  pickupInstructions  String?
  packaging           String
  status              String   @default("PENDING_APPROVAL")

  donorId             String
  volunteerId         String?

  createdAt           DateTime @default(now())
}